# Copy this file to .env and fill in your own keys.
# Never commit .env.

# Market/fundamental data
FMP_API_KEY=
MASSIVE_API_KEY=
FINNHUB_API_KEY=
BENZINGA_API_KEY=
COINGECKO_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# AI/research providers
GOOGLE_API_KEY=
GEMINI_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
CODEX_AUTH_PATH=~/.codex/auth.json
ARTHA_GPT_MODEL=gpt-5.5
ARTHA_GPT_FALLBACK_MODEL=gpt-5.5-codex
ARTHA_GPT_REASONING_EFFORT=xhigh
ARTHA_GEMINI_TECHNICAL_MODEL=gemini-3.1-pro-preview
ARTHA_GEMINI_FLASH_MODEL=gemini-3.5-flash

# Telegram delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SEC EDGAR contact string
SEC_USER_AGENT=ArthaPersonalResearch/1.0 (your-email@example.com)

# Broad scan/funnel controls
ARTHA_FMP_API_PLAN=premium
ARTHA_FMP_CALLS_PER_MINUTE=240
ARTHA_FUNNEL_RANK_TOP_N=150
ARTHA_FUNNEL_ENRICH_MAX=45
ARTHA_OPPORTUNITY_SCOUT_ENABLED=true
ARTHA_OPPORTUNITY_SCOUT_MAX_TOOL_CALLS=8

# Robinhood/OpenClaw broker bridge.
# Defaults are intentionally safe: review-only, dry-run, and kill-switch enabled.
ARTHA_ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ARTHA_ROBINHOOD_AGENTIC_ACCOUNT_NUMBER=
ARTHA_ROBINHOOD_EXPECTED_ACCOUNT_TYPE=cash
ARTHA_ROBINHOOD_EXPECTED_ACCOUNT_NICKNAME=Agentic
ARTHA_ROBINHOOD_REVIEW_ONLY=true
ARTHA_ROBINHOOD_DRY_RUN_ONLY=true
ARTHA_ROBINHOOD_AGENTIC_ENABLED=false
ARTHA_ROBINHOOD_KILL_SWITCH=true
ARTHA_ROBINHOOD_PILOT_MAX_ACCOUNT_VALUE=350
ARTHA_ROBINHOOD_MAX_POSITION_DOLLARS=50
ARTHA_ROBINHOOD_MAX_TRADES_PER_DAY=2
ARTHA_ROBINHOOD_MAX_SPREAD_PCT=0.01
ARTHA_ROBINHOOD_RECONCILIATION_SNAPSHOT_MAX_AGE_MINUTES=10
ARTHA_ROBINHOOD_AUTO_BUY_ENABLED=false
ARTHA_ROBINHOOD_AUTO_BUY_MAX_ORDER_DOLLARS=25
ARTHA_ROBINHOOD_AUTO_BUY_MAX_DAILY_DOLLARS=50
ARTHA_OPENCLAW_TMP_DIR=/tmp
